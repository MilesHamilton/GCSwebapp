# Mapbox public access token — needed from Phase 1 onward.
# Get one free at https://account.mapbox.com/access-tokens/
# Copy this file to .env (gitignored) and paste your token.
VITE_MAPBOX_TOKEN=

# Gateway location (optional in dev — defaults to ws://localhost:8000/ws).
# In prod, render.yaml wires VITE_GATEWAY_HOST from the gateway service's host and the
# client speaks wss://<host>/ws. Set VITE_WS_URL to override the whole URL if needed.
# VITE_GATEWAY_HOST=
# VITE_WS_URL=
